// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum TeamRole {
  LEAD
  MEMBER
}

enum ProjectRole {
  OWNER
  LEAD
  MEMBER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  AT_RISK
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DependencyType {
  BLOCKS
  RELATES_TO
}

enum NotificationType {
  RISK_ALERT
  BLOCKER
  TASK_ASSIGNMENT
  PROJECT_UPDATE
  AI_RECOMMENDATION
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  DEPENDENCY_ADDED
  RISK_UPDATED
  BLOCKER_DETECTED
  AI_EXPLANATION_CREATED
}

enum AITargetType {
  PROJECT
  TASK
  TEAM
}

enum AIConfidence {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  passwordHash String
  avatarUrl String?
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  teamMemberships TeamMember[]
  projectMembers  ProjectMember[]
  assignedTasks   Task[]            @relation("TaskAssignee")
  aiRecommendedTasks Task[]         @relation("TaskAIRecommendation")
  createdTasks    Task[]            @relation("TaskCreator")
  activities      ProjectActivity[] @relation("ActivityActor")
  notifications   Notification[]    @relation("NotificationRecipient")
  eventLogs       EventLog[]        @relation("EventLogActor")
  refreshTokens   RefreshToken[]
  invites         OrganizationInvite[]
  ownedProjects   Project[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  teams         Team[]
  projects      Project[]
  tasks         Task[]
  activities    ProjectActivity[]
  events        EventLog[]
  aiOutputs     AIExplanation[]
  notifications Notification[]
  invites       OrganizationInvite[]
}

model Membership {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId, role])
  @@index([userId])
}

model OrganizationInvite {
  id         String                   @id @default(uuid())
  orgId      String
  email      String
  role       OrgRole                  @default(MEMBER)
  status     OrganizationInviteStatus @default(PENDING)
  tokenHash  String
  inviterId  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime                 @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  inviter      User         @relation(fields: [inviterId], references: [id])

  @@unique([orgId, email])
  @@index([orgId, status])
  @@index([email])
}

model Team {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  members      TeamMember[]
  projects     Project[]

  @@index([orgId])
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([teamId, role])
}

model Project {
  id          String        @id @default(uuid())
  orgId       String
  ownerId     String
  teamId      String?
  name        String
  slug        String?
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id])
  owner        User              @relation(fields: [ownerId], references: [id])
  team         Team?             @relation(fields: [teamId], references: [id])
  members      ProjectMember[]
  tasks        Task[]
  activities   ProjectActivity[]
  aiOutputs    AIExplanation[]

  @@index([orgId, status])
  @@index([ownerId])
  @@index([teamId])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  skills    String[]    @default([])
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId, role])
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assigneeId     String?
  aiRecommendedUserId String?
  aiRecommendationScore Float?
  aiRecommendationConfidence AIConfidence?
  aiRecommendationExplanation Json?
  createdById    String
  estimateHours  Float?
  startDate      DateTime?
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  project      Project           @relation(fields: [projectId], references: [id])
  assignee     User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  aiRecommendedUser User?        @relation("TaskAIRecommendation", fields: [aiRecommendedUserId], references: [id])
  creator      User              @relation("TaskCreator", fields: [createdById], references: [id])
  dependencies TaskDependency[]  @relation("TaskDependencies")
  dependents   TaskDependency[]  @relation("TaskDependents")
  aiOutputs    AIExplanation[]
  activities   ProjectActivity[] @relation("TaskActivity")

  @@index([organizationId, projectId])
  @@index([projectId, status])
  @@index([assigneeId, status])
}

model TaskDependency {
  id              String   @id @default(uuid())
  taskId          String
  dependsOnTaskId String
  createdAt       DateTime @default(now())

  // task depends on dependsOnTask
  task            Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask   Task @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
}

model AIExplanation {
  id         String       @id @default(uuid())
  orgId      String
  projectId  String?
  taskId     String?
  targetType AITargetType
  summary    String
  rationale  String
  evidence   Json
  confidence AIConfidence
  actions    Json?
  eventId    String?
  createdAt  DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  task         Task?        @relation(fields: [taskId], references: [id])
  // Explanation traceability back to the originating event
  event        EventLog?    @relation("EventLogAIOutputs", fields: [eventId], references: [id])

  @@index([orgId, targetType])
  @@index([projectId])
  @@index([taskId])
}

model ProjectActivity {
  id        String       @id @default(uuid())
  orgId     String
  projectId String
  taskId    String?
  actorId   String?
  type      ActivityType
  payload   Json
  createdAt DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  // Optional task context for activity events
  task         Task?        @relation("TaskActivity", fields: [taskId], references: [id])
  actor        User?        @relation("ActivityActor", fields: [actorId], references: [id])

  @@index([orgId, createdAt])
  @@index([projectId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  orgId     String
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  recipient    User         @relation("NotificationRecipient", fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([userId, readAt])
}

model EventLog {
  id         String   @id @default(uuid())
  orgId      String
  actorId    String?
  entityType String
  entityId   String
  eventType  String
  payload    Json
  createdAt  DateTime @default(now())

  organization Organization    @relation(fields: [orgId], references: [id])
  actor        User?           @relation("EventLogActor", fields: [actorId], references: [id])
  // AI explanations generated from this event
  aiOutputs    AIExplanation[] @relation("EventLogAIOutputs")

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}
